---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const sorted = articles.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
  return sorted.map((article, index) => ({
    params: { slug: article.slug },
    props: {
      article,
      allArticles: sorted,
      currentIndex: index,
    },
  }));
}

const { article, allArticles, currentIndex } = Astro.props;
const { Content, headings } = await article.render();

// Group articles for nested nav
const nav = [
  {
    title: '快速开始',
    items: [
      { title: '欢迎使用', href: '/', num: '001' },
      { title: '快速开始', href: '/articles/getting-started', num: '002' },
    ],
  },
  {
    title: '主题配置',
    items: [
      { title: '配置选项', href: '/articles/configuration', num: '003' },
      { title: '自定义样式', href: '/articles/styling', num: '004' },
      { title: '高级特性', href: '/articles/advanced-features', num: '005' },
    ],
  },
];

// Prev/Next
const prev = currentIndex > 0 ? allArticles[currentIndex - 1] : null;
const next = currentIndex < allArticles.length - 1 ? allArticles[currentIndex + 1] : null;
---

<BaseLayout title={article.data.title} description={article.data.description} nav={nav}>
  <div class="article-with-toc">
    <article>
      <header class="article-header">
        <nav class="breadcrumb">
          <a href="/">首页</a>
          <span>/</span>
          <span>{article.data.title}</span>
        </nav>
        <h1 class="article-title">{article.data.title}</h1>
        {article.data.description && (
          <p class="article-meta">{article.data.description}</p>
        )}
      </header>

      <div class="article-content">
        <Content />
      </div>

      <nav class="article-nav">
        {prev ? (
          <a href={`/articles/${prev.slug}`} class="article-nav-link prev">
            <div class="article-nav-label">← 上一篇</div>
            <div class="article-nav-title">{prev.data.title}</div>
          </a>
        ) : <div></div>}
        {next ? (
          <a href={`/articles/${next.slug}`} class="article-nav-link next">
            <div class="article-nav-label">下一篇 →</div>
            <div class="article-nav-title">{next.data.title}</div>
          </a>
        ) : <div></div>}
      </nav>
    </article>

    <aside class="toc-sidebar">
      <TableOfContents headings={headings} />
    </aside>
  </div>
</BaseLayout>
