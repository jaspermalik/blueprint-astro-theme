---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { generateSidebar, flattenGroupToReceipt } from '../utils/sidebar';
import Receipt from '../components/Receipt.astro';

const allDocs = await getCollection('docs');
const sidebar = generateSidebar(allDocs);
---

<BaseLayout title="Blueprint Astro Theme" nav={sidebar.groups}>
  <div class="home-header">
    <h1 class="home-title">Blueprint Astro Theme</h1>
    <div class="home-subtitle-tech">DOCUMENTATION OVERVIEW / v1.0</div>
    <p class="home-subtitle">A clean documentation theme, ported from Blueprint Docs</p>
  </div>

  <div class="toc-grid">
    {sidebar.groups.map((group) => (
      <Receipt label={group.title || ''} lines={flattenGroupToReceipt(group, allDocs)} />
    ))}
  </div>

  <section style="margin-top: 48px;">
    <h2 style="font-size: 20px; margin-bottom: 16px;">Features</h2>
    <ul style="list-style: disc; padding-left: 24px;">
      <li style="margin-bottom: 8px;">Clean sidebar navigation layout</li>
      <li style="margin-bottom: 8px;">Supports light / dark / auto theme switching</li>
      <li style="margin-bottom: 8px;">Responsive design, mobile-friendly</li>
      <li style="margin-bottom: 8px;">Easy to customize with CSS variables</li>
      <li style="margin-bottom: 8px;">Table of contents component support</li>
    </ul>
  </section>
</BaseLayout>
