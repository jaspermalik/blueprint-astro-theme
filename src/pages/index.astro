---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { generateSidebar, flattenGroupForBoardingPass } from '../utils/sidebar';
import BoardingPass from '../components/BoardingPass.astro';

const allDocs = await getCollection('docs');
const sidebar = generateSidebar(allDocs);
---

<BaseLayout title="Blueprint Astro Theme" nav={sidebar.groups}>
  <div class="home-header">
    <h1 class="home-title">Blueprint Astro Theme</h1>
    <div class="home-subtitle-tech">DOCUMENTATION OVERVIEW / v1.0</div>
    <p class="home-subtitle">一个简洁的文档主题，移植自 Blueprint Docs</p>
  </div>

  <div class="toc-grid">
    {sidebar.groups.map((group) => (
      <BoardingPass
        label={group.title || ''}
        rows={flattenGroupForBoardingPass(group, allDocs)}
      />
    ))}
  </div>

  <section style="margin-top: 48px;">
    <h2 style="font-size: 20px; margin-bottom: 16px;">特性</h2>
    <ul style="list-style: disc; padding-left: 24px;">
      <li style="margin-bottom: 8px;">简洁的侧边栏导航布局</li>
      <li style="margin-bottom: 8px;">支持亮色/暗色/自动主题切换</li>
      <li style="margin-bottom: 8px;">响应式设计，适配移动端</li>
      <li style="margin-bottom: 8px;">基于 CSS 变量易于定制</li>
      <li style="margin-bottom: 8px;">文章目录组件支持</li>
    </ul>
  </section>
</BaseLayout>