---
import TocGroup from './TocGroup.astro';
import type { SidebarItem, SidebarGroup } from '../utils/sidebar';

interface Props {
  group: SidebarGroup;
  docs: any[];
  isNested?: boolean;
  isLast?: boolean;
}

const { group, docs, isNested = false, isLast = false } = Astro.props;

function isItem(item: SidebarItem | SidebarGroup): item is SidebarItem {
  return 'href' in item;
}

function getDoc(href: string) {
  return docs.find(d => `/docs/${d.id}` === href);
}
---

<div class="toc-group">
  {group.title && (
    <div class="toc-group-title">
      {isNested && <span class="bp-tree-line">{isLast ? '└─' : '├─'}</span>}
      {isNested && <span class="bp-label">{group.title.toUpperCase()}</span>}
      {!isNested && group.title}
    </div>
  )}
  {group.items.map((item, index) => {
    if (isItem(item)) {
      const doc = getDoc(item.href);
      return (
        <div class="toc-item">
          {isNested && <span class="bp-tree-line">{index === group.items.length - 1 ? '  └─' : '  ├─'}</span>}
          <a href={item.href}>{item.title}</a>
          {doc?.data.description && (
            <p class="toc-item-desc">{doc.data.description}</p>
          )}
        </div>
      );
    } else {
      const isLastSubgroup = index === group.items.length - 1;
      return <TocGroup group={item} docs={docs} isNested={true} isLast={isLastSubgroup} />;
    }
  })}
</div>