---
import type { BoardingPassRow } from '../utils/sidebar';

interface Props {
  label: string;
  rows: BoardingPassRow[];
}

const { label, rows } = Astro.props;
---

<article class="bp-card">
  {label && (
    <header class="bp-header">
      <div class="bp-brand-bar" aria-hidden="true"></div>
      <span class="bp-flight-num">{label}</span>
    </header>
  )}

  <div class="bp-body">
    {rows.map((row) => {
      switch (row.type) {
        case 'route':
          return (
            <a href={row.href} class="bp-route">
              <span class="bp-route-origin">{row.origin}</span>
              <span class="bp-route-arrow">→</span>
              <span class="bp-route-dest">{row.title}</span>
            </a>
          );
        case 'doc':
          return (
            <a href={row.href} class="bp-row">
              <span class="bp-row-num">{row.num ?? '—'}</span>
              <span class="bp-row-content">
                <span class="bp-row-title">{row.title}</span>
                {row.description && (
                  <span class="bp-row-desc">{row.description}</span>
                )}
              </span>
            </a>
          );
        case 'divider':
          return <div class="bp-section-divider" aria-hidden="true"></div>;
        default:
          return null;
      }
    })}
  </div>

  <div class="bp-tear-line" aria-hidden="true"></div>
</article>
