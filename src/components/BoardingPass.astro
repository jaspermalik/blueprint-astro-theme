---
import type { BoardingPassRow } from '../utils/sidebar';

interface Props {
  label: string;
  rows: BoardingPassRow[];
}

const { label, rows } = Astro.props;
---

<article class="boarding-pass">
  {label && (
    <header class="bp-header">
      <span class="bp-label">{label}</span>
    </header>
  )}

  <section class="bp-rows">
    {rows.map((row) => (
      row.type === 'doc' ? (
        <a
          href={row.href}
          class:list={['bp-row', `bp-row--indent-${Math.min(row.level, 2)}`]}
        >
          <span class="bp-row-num">{row.num ?? '—'}</span>
          <span class="bp-row-content">
            <span class="bp-row-title">{row.title}</span>
            {row.description && (
              <span class="bp-row-desc">{row.description}</span>
            )}
          </span>
        </a>
      ) : (
        <div class:list={['bp-row', 'bp-row-category', `bp-row--indent-${Math.min(row.level, 2)}`]}
        >
          <span class="bp-row-num">—</span>
          <span class="bp-row-content">
            <span class="bp-row-title">{row.title}</span>
          </span>
        </div>
      )
    ))}
  </section>

  <div class="bp-tear-line" aria-hidden="true"></div>
</article>
