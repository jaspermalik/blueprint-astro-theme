---
// Sidebar - Pure UI component, supports nested nav groups
interface NavItem {
  title: string;
  href: string;
  num?: string;
}

interface NavGroup {
  title?: string;  // Optional - if no title, items render without group
  items: (NavItem | NavGroup)[];
}

interface Props {
  logo?: string;
  subtitle?: string;
  nav?: NavGroup[];
}

const {
  logo = 'Blueprint',
  subtitle = 'Astro Theme',
  nav = []
} = Astro.props;

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  return currentPath === href || currentPath === href + '/';
}

function isItem(item: NavItem | NavGroup): item is NavItem {
  return 'href' in item;
}
---

<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <a href="/" class="sidebar-logo">{logo}</a>
    <div class="sidebar-subtitle">{subtitle}</div>
  </div>

  <div class="sidebar-search">
    <input
      type="text"
      class="search-input"
      placeholder="搜索... (⌘K)"
      readonly
    />
  </div>

  <nav class="sidebar-nav">
    {nav.map((group) => (
      <div class="nav-group">
        {group.title && <div class="nav-group-title">{group.title}</div>}
        {group.items.map((item) => {
          if (isItem(item)) {
            // Direct nav item
            return (
              <a
                href={item.href}
                class={`nav-item ${isActive(item.href) ? 'active' : ''}`}
              >
                {item.num && <span class="nav-item-num">{item.num}</span>}
                <span>{item.title}</span>
              </a>
            );
          } else {
            // Nested group
            return (
              <div class="nav-subgroup">
                {item.title && <div class="nav-subgroup-title">{item.title}</div>}
                {item.items.map((subItem) => (
                  <a
                    href={subItem.href}
                    class={`nav-item nav-item-nested ${isActive(subItem.href) ? 'active' : ''}`}
                  >
                    {subItem.num && <span class="nav-item-num">{subItem.num}</span>}
                    <span>{subItem.title}</span>
                  </a>
                ))}
              </div>
            );
          }
        })}
      </div>
    ))}
  </nav>

  <div class="sidebar-footer">
    <span style="font-size: 11px; color: var(--c-text-sub);">Blueprint Astro</span>
  </div>
</aside>

<button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle menu">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
    <line x1="3" y1="12" x2="21" y2="12" />
    <line x1="3" y1="6" x2="21" y2="6" />
    <line x1="3" y1="18" x2="21" y2="18" />
  </svg>
</button>

<div class="sidebar-overlay" id="sidebar-overlay"></div>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');

  function toggleSidebar() {
    sidebar?.classList.toggle('open');
  }

  menuBtn?.addEventListener('click', toggleSidebar);
  overlay?.addEventListener('click', toggleSidebar);

  document.querySelectorAll('.nav-item').forEach(link => {
    link.addEventListener('click', () => {
      sidebar?.classList.remove('open');
    });
  });
</script>
